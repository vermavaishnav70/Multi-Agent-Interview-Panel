# LLM providers
NIM_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
SARVAM_API_KEY=
ELEVENLABS_API_KEY=
NIM_STT_URL=grpc.nvcf.nvidia.com:443
NIM_STT_MODEL=openai/whisper-large-v3
NIM_STT_FUNCTION_ID=
NIM_STT_LANGUAGE=en
NIM_TTS_URL=
NIM_TTS_MODEL=nvidia/magpie-tts-zeroshot
NIM_TTS_FUNCTION_ID=
NIM_TTS_LANGUAGE=en-US
NIM_TTS_SAMPLE_RATE=22050
NIM_TTS_ZERO_SHOT_QUALITY=20
NIM_TTS_PROMPT_FILE=
NIM_TTS_PROMPT_TRANSCRIPT=
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=transcribe
SARVAM_STT_LANGUAGE=unknown
ELEVENLABS_STT_MODEL=scribe_v2
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_LANGUAGE=en-IN
SARVAM_TTS_OUTPUT_CODEC=mp3

# Supabase Postgres
# Direct connection example:
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# Supabase may show this as postgres://...; the backend will normalize it to
# postgresql+asyncpg://... automatically.
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Optional MCP Toolbox Postgres source values for backend/tools.yaml
SUPABASE_DB_HOST=db.[PROJECT-REF].supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=[PASSWORD]

# App URLs
CORS_ORIGINS=["http://localhost:3000"]
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
